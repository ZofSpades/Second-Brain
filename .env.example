# Copy this file to .env and fill in your values.
# NEVER commit your actual .env file — it is gitignored.

# PostgreSQL connection string (e.g. Neon, Supabase, Railway)
DATABASE_URL="postgresql://user:password@host/dbname?sslmode=require"

# Google Gemini API key — https://aistudio.google.com/app/apikey
GOOGLE_AI_API_KEY="your-google-ai-api-key"

# Public URL of your app (no trailing slash)
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# NextAuth secret — generate one with: openssl rand -base64 32
AUTH_SECRET="your-nextauth-secret"

# Required for NextAuth when not behind a trusted proxy
AUTH_TRUST_HOST=true

# CORS allowed origin for the public API (set to your domain in production)
CORS_ORIGIN="*"

NODE_ENV="development"
